<script>
// ── WIKIPEDIA IMAGE LOADER ──
async function fetchWikiImage(slug) {
  try {
    const res = await fetch(
      `https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(slug)}`,
      { headers: { 'Accept': 'application/json' } }
    );
    if (!res.ok) return null;
    const data = await res.json();
    return {
      img: data.thumbnail ? data.thumbnail.source.replace(/\/\d+px-/, '/600px-') : null,
      url: data.content_urls?.desktop?.page || `https://en.wikipedia.org/wiki/${encodeURIComponent(slug)}`
    };
  } catch { return null; }
}

async function loadWikiImages() {
  const slots = document.querySelectorAll('.img-slot[data-wiki]');
  // Batch in groups of 6 to avoid rate limiting
  const batchSize = 6;
  for (let i = 0; i < slots.length; i += batchSize) {
    const batch = Array.from(slots).slice(i, i + batchSize);
    await Promise.all(batch.map(async slot => {
      const slug = slot.dataset.wiki;
      if (!slug) return;
      const result = await fetchWikiImage(slug);
      if (result && result.img) {
        const a = document.createElement('a');
        a.href = result.url;
        a.target = '_blank';
        a.rel = 'noopener';
        a.style.cssText = 'display:block;width:100%;height:100%;';
        const img = document.createElement('img');
        img.src = result.img;
        img.alt = slug.replace(/_/g, ' ');
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        img.loading = 'lazy';
        // on error, keep placeholder
        img.onerror = () => { a.remove(); };
        a.appendChild(img);
        slot.innerHTML = '';
        slot.style.border = 'none';
        slot.style.background = 'none';
        slot.style.padding = '0';
        slot.appendChild(a);
      }
    }));
  }
}

document.addEventListener('DOMContentLoaded', loadWikiImages);

// ── CITY / SECTION SWITCHING ──
function showCity(city, btn) {
  document.querySelectorAll('.city').forEach(c => c.classList.remove('active'));
  document.querySelectorAll('.city-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('city-' + city).classList.add('active');
  btn.classList.add('active');
  // reset section to arch
  const archBtn = document.querySelector('#city-' + city + ' .section-btn');
  if (archBtn) {
    document.querySelectorAll('#city-' + city + ' .section-btn').forEach(b => b.classList.remove('active'));
    archBtn.classList.add('active');
    document.querySelectorAll('#city-' + city + ' .section-view').forEach(v => v.classList.remove('active'));
    document.getElementById(city + '-arch').classList.add('active');
  }
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function showSection(city, section, btn) {
  document.querySelectorAll('#city-' + city + ' .section-view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('#city-' + city + ' .section-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(city + '-' + section).classList.add('active');
  btn.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── FILTER PANEL TOGGLE ──
function toggleFilterPanel(ctx) {
  const panel = document.getElementById(ctx + '-filters');
  const btn = document.getElementById(ctx + '-filter-toggle-btn');
  const isOpen = panel.classList.toggle('open');
  btn.innerHTML = '';
  const icon = document.createElement('span');
  icon.className = 'filter-icon';
  icon.textContent = isOpen ? '✕' : '⊞';
  btn.appendChild(icon);
  btn.appendChild(document.createTextNode(' ' + (isOpen ? 'Close' : 'Filter')));
}

// ── FILTER SYSTEM ──
const activeFilters = { nyc: {}, boston: {}, 'nyc-arch': {}, 'boston-arch': {} };

function toggleFilter(btn, ctx) {
  const filterType = btn.dataset.filter;
  const value = btn.dataset.value;

  if (!activeFilters[ctx]) activeFilters[ctx] = {};
  if (!activeFilters[ctx][filterType]) activeFilters[ctx][filterType] = new Set();
  const set = activeFilters[ctx][filterType];

  if (set.has(value)) {
    set.delete(value);
    btn.classList.remove('active');
  } else {
    set.add(value);
    btn.classList.add('active');
  }

  if (set.size === 0) delete activeFilters[ctx][filterType];

  applyFilters(ctx);
  updateToggleBtn(ctx);
}

function updateToggleBtn(ctx) {
  const btn = document.getElementById(ctx + '-filter-toggle-btn');
  if (!btn) return;
  const af = activeFilters[ctx] || {};
  const hasActive = Object.keys(af).length > 0;
  btn.classList.toggle('has-active', hasActive);
}

function clearFilters(ctx) {
  activeFilters[ctx] = {};
  document.querySelectorAll(`#${ctx}-filters .filter-pill`).forEach(p => p.classList.remove('active'));
  applyFilters(ctx);
  updateToggleBtn(ctx);
}

function applyFilters(ctx) {
  // ctx can be 'nyc', 'boston', 'nyc-arch', 'boston-arch'
  let sectionId;
  if (ctx === 'nyc-arch') sectionId = 'nyc-arch';
  else if (ctx === 'boston-arch') sectionId = 'boston-arch';
  else sectionId = ctx + '-life';
  const entries = document.querySelectorAll('#' + sectionId + ' .entry[data-type]');
  const filters = activeFilters[ctx] || {};
  const hasFilters = Object.keys(filters).length > 0;

  let visibleCount = 0;

  entries.forEach(entry => {
    if (!hasFilters) {
      entry.classList.remove('hidden');
      visibleCount++;
      return;
    }

    let match = true;

    for (const [filterType, values] of Object.entries(filters)) {
      if (values.size === 0) continue;

      let entryVal = '';
      if (filterType === 'type') entryVal = entry.dataset.type || '';
      else if (filterType === 'cuisine') entryVal = entry.dataset.cuisine || '';
      else if (filterType === 'cost') entryVal = entry.dataset.cost || '';
      else if (filterType === 'hood') entryVal = entry.dataset.hood || '';
      else if (filterType === 'arch') entryVal = entry.dataset.arch || '';

      // check if any active value matches entry's data
      let found = false;
      for (const v of values) {
        if (entryVal.includes(v)) { found = true; break; }
      }
      if (!found) { match = false; break; }
    }

    if (match) {
      entry.classList.remove('hidden');
      visibleCount++;
    } else {
      entry.classList.add('hidden');
    }
  });

  // borough headers — hide if all entries below are hidden
  const boroughHeaders = document.querySelectorAll('#' + sectionId + ' .borough-header');
  boroughHeaders.forEach(header => {
    let next = header.nextElementSibling;
    let hasVisible = false;
    while (next && !next.classList.contains('borough-header')) {
      if (next.classList.contains('entry') && !next.classList.contains('hidden')) {
        hasVisible = true;
        break;
      }
      next = next.nextElementSibling;
    }
    header.style.display = hasVisible ? '' : 'none';
  });

  // section labels (Buildings / Public Space) — hide if all entries below are hidden
  const sectionLabels = document.querySelectorAll('#' + sectionId + ' > .section-label');
  sectionLabels.forEach(label => {
    let next = label.nextElementSibling;
    let hasVisible = false;
    while (next && !next.classList.contains('section-label') && !next.classList.contains('critical-section') && !next.classList.contains('upcoming-section')) {
      if (next.classList.contains('entry') && !next.classList.contains('hidden')) {
        hasVisible = true;
        break;
      }
      next = next.nextElementSibling;
    }
    label.style.display = hasVisible ? '' : 'none';
  });

  // no results message
  const noResults = document.getElementById(ctx + '-no-results');
  noResults.style.display = visibleCount === 0 ? 'block' : 'none';

  // count
  const countEl = document.getElementById(ctx + '-count');
  if (countEl) {
    const total = entries.length;
    countEl.textContent = hasFilters ? visibleCount + ' of ' + total : '';
  }
}
</script>

