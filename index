<div class="entry" data-type="residential" data-hood="lincoln" data-arch="gropius">
  <div class="img-slot" data-wiki="Gropius_House"><span>Add image</span></div>
  <div class="entry-row"><span class="entry-label">Gropius, Walter</span><span class="entry-cost">1938</span></div>
