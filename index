<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Field Guide</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Spectral:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:     #f8f7f4;
  --white:  #ffffff;
  --ink:    #0f0f0d;
  --mid:    #5c5c58;
  --low:    #a8a8a2;
  --rule:   #e2e0d8;
  --blue:   #a8c4d8;
  --bd:     #3a6e8f;
  --bbg:    #f0f5f9;
  --display:'Cormorant Garamond', Georgia, serif;
  --body:   'Spectral', Georgia, serif;
  --mono:   'DM Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body { background: var(–bg); color: var(–ink); font-family: var(–body); line-height: 1.65; -webkit-tap-highlight-color: transparent; }

/* ── TOP BAR ── */
.top-bar {
position: sticky; top: 0; z-index: 200;
background: var(–white); border-bottom: 1px solid var(–rule);
display: flex; align-items: center; justify-content: space-between;
padding: 0 1.25rem; height: 46px;
}
.site-name {
font-family: var(–mono); font-size: 0.55rem;
letter-spacing: 0.2em; text-transform: uppercase; color: var(–low);
}
.city-tabs { display: flex; gap: 0.15rem; }
.city-btn {
font-family: var(–mono); font-size: 0.55rem; letter-spacing: 0.13em;
text-transform: uppercase; color: var(–low); background: none; border: none;
padding: 0.4rem 0.7rem; border-radius: 3px; cursor: pointer; transition: all 0.15s;
}
.city-btn:hover { color: var(–ink); }
.city-btn.active { background: var(–blue); color: var(–white); }

/* ── SECTION TABS ── */
.section-bar {
background: var(–white); border-bottom: 1px solid var(–rule);
display: flex; padding: 0 1.25rem;
}
.section-btn {
font-family: var(–mono); font-size: 0.52rem; letter-spacing: 0.15em;
text-transform: uppercase; color: var(–low); background: none; border: none;
border-bottom: 2px solid transparent; padding: 0.65rem 0.75rem 0.65rem 0;
margin-right: 1rem; cursor: pointer; transition: all 0.15s;
}
.section-btn.active { color: var(–ink); border-bottom-color: var(–ink); }

/* ── VIEWS ── */
.city { display: none; }
.city.active { display: block; }
.section-view { display: none; }
.section-view.active { display: block; }

/* ── CITY HEADER ── */
.city-header { padding: 2.5rem 1.25rem 1.75rem; border-bottom: 1px solid var(–rule); }
.city-header h1 {
font-family: var(–display); font-size: clamp(3rem, 11vw, 5.5rem);
font-weight: 300; letter-spacing: -0.01em; line-height: 1.0; color: var(–ink);
}
.city-header-sub {
font-family: var(–mono); font-size: 0.52rem; letter-spacing: 0.15em;
text-transform: uppercase; color: var(–low); margin-top: 0.6rem;
}

/* ── ALPHA INDEX ── */
.alpha-index {
padding: 0.75rem 1.25rem; border-bottom: 1px solid var(–rule);
display: flex; flex-wrap: wrap; gap: 0.3rem; background: var(–white);
}
.alpha-index a {
font-family: var(–mono); font-size: 0.5rem; letter-spacing: 0.1em;
text-transform: uppercase; color: var(–mid); text-decoration: none;
padding: 0.2rem 0.4rem; border: 1px solid var(–rule); border-radius: 2px;
transition: all 0.12s;
}
.alpha-index a:hover { border-color: var(–bd); color: var(–bd); }

/* ── SECTION LABEL ── */
.section-label {
padding: 1.5rem 1.25rem 0.5rem; font-family: var(–mono);
font-size: 0.5rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(–low);
}

/* ── FILTER TOGGLE BAR ── */
.filter-toggle-bar {
position: sticky; top: 46px; z-index: 100;
background: var(–white); border-bottom: 1px solid var(–rule);
padding: 0 1.25rem; height: 38px;
display: flex; align-items: center; justify-content: space-between;
}
.filter-toggle-btn {
font-family: var(–mono); font-size: 0.5rem; letter-spacing: 0.14em;
text-transform: uppercase; color: var(–mid); background: none; border: none;
cursor: pointer; display: flex; align-items: center; gap: 0.4rem; padding: 0;
transition: color 0.12s;
}
.filter-toggle-btn:hover { color: var(–ink); }
.filter-toggle-btn.has-active { color: var(–ink); font-weight: 500; }
.filter-toggle-count {
font-family: var(–mono); font-size: 0.44rem; letter-spacing: 0.1em; color: var(–low);
}

/* ── FILTER PANEL (hidden by default) ── */
.filter-bar {
background: var(–white); border-bottom: 1px solid var(–rule);
padding: 0.75rem 1.25rem; display: none; flex-direction: column; gap: 0.5rem;
}
.filter-bar.open { display: flex; }
.filter-row { display: flex; align-items: center; gap: 0.3rem; flex-wrap: wrap; }
.filter-group-label {
font-family: var(–mono); font-size: 0.44rem; letter-spacing: 0.15em;
text-transform: uppercase; color: var(–low); margin-right: 0.15rem; white-space: nowrap; flex-shrink: 0;
}
.filter-pill {
font-family: var(–mono); font-size: 0.46rem; letter-spacing: 0.1em;
text-transform: uppercase; color: var(–mid); background: none;
border: 1px solid var(–rule); padding: 0.2rem 0.5rem; border-radius: 99px;
cursor: pointer; white-space: nowrap; transition: all 0.12s; -webkit-appearance: none;
}
.filter-pill:hover { border-color: var(–bd); color: var(–bd); }
.filter-pill.active { background: var(–ink); color: var(–white); border-color: var(–ink); }
.filter-actions {
display: flex; align-items: center; gap: 0.75rem; padding-top: 0.25rem;
border-top: 1px solid var(–rule); margin-top: 0.1rem;
}
.filter-clear {
font-family: var(–mono); font-size: 0.44rem; letter-spacing: 0.1em;
text-transform: uppercase; color: var(–low); background: none; border: none;
cursor: pointer; padding: 0; text-decoration: underline; text-underline-offset: 2px;
}
.filter-count {
font-family: var(–mono); font-size: 0.44rem; letter-spacing: 0.1em; color: var(–low);
}

/* ── NO RESULTS ── */
.no-results {
padding: 3rem 1.25rem; font-family: var(–mono); font-size: 0.52rem;
letter-spacing: 0.14em; text-transform: uppercase; color: var(–low); display: none;
}

/* ── BOROUGH HEADER ── */
.borough-header {
padding: 1.1rem 1.25rem 0.35rem; font-family: var(–mono);
font-size: 0.5rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(–bd);
border-top: 1px solid var(–rule);
}

/* ── ENTRY ── */
.entry {
padding: 1.4rem 1.25rem; border-bottom: 1px solid var(–rule);
transition: opacity 0.15s;
}
.entry.hidden { display: none; }

.img-slot {
width: 100%; aspect-ratio: 3/2; background: var(–bbg);
border: 1px dashed var(–blue); display: flex; align-items: center;
justify-content: center; margin-bottom: 1rem; border-radius: 2px;
}
.img-slot span {
font-family: var(–mono); font-size: 0.44rem; letter-spacing: 0.14em;
text-transform: uppercase; color: var(–blue);
}

.entry-row {
display: flex; justify-content: space-between; align-items: baseline;
gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.15rem;
}
.entry-label {
font-family: var(–mono); font-size: 0.52rem; letter-spacing: 0.13em;
text-transform: uppercase; color: var(–bd);
}
.entry-cost {
font-family: var(–mono); font-size: 0.5rem; color: var(–low); flex-shrink: 0;
letter-spacing: 0.05em;
}

.entry-title {
font-family: var(–display); font-size: 1.45rem; font-weight: 400;
line-height: 1.15; color: var(–ink); margin-bottom: 0.2rem;
}

/* ── CREDENTIAL ICONS ── */
.icons {
display: flex; gap: 0.35rem; flex-wrap: wrap; margin-bottom: 0.5rem; align-items: center;
}
.icon {
font-family: var(–mono); font-size: 0.44rem; letter-spacing: 0.08em;
text-transform: uppercase; color: var(–ink); border: 1px solid var(–ink);
padding: 0.12rem 0.38rem; border-radius: 2px; white-space: nowrap; line-height: 1.6;
}
.icon-star  { background: var(–ink); color: var(–white); }
.icon-bib   { }
.icon-nyt   { }
.icon-jbf   { }
.icon-iconic{ border-style: double; }
.icon-free  { border-color: var(–low); color: var(–low); }
.icon-landmark { border-color: var(–bd); color: var(–bd); }

.entry-meta {
font-family: var(–mono); font-size: 0.48rem; letter-spacing: 0.1em;
text-transform: uppercase; color: var(–low); margin-bottom: 0.8rem;
display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center;
}
.entry-tag {
border: 1px solid var(–rule); padding: 0.1rem 0.35rem; border-radius: 2px;
}

.entry-blurb {
font-family: var(–body); font-size: 0.9rem; color: var(–mid);
line-height: 1.7; margin-bottom: 0.9rem;
}

.map-link {
display: inline-block; font-family: var(–mono); font-size: 0.48rem;
letter-spacing: 0.12em; text-transform: uppercase; color: var(–bd);
text-decoration: none; border: 1px solid var(–blue); padding: 0.35rem 0.65rem;
border-radius: 2px; transition: all 0.12s;
}
.map-link:hover { background: var(–blue); color: var(–white); }
.map-links { display: flex; flex-wrap: wrap; gap: 0.4rem; }

/* ── CRITICALLY NOTED ── */
.critical-section { background: var(–ink); }
.critical-section .section-label { color: rgba(255,255,255,0.25); }
.critical-section .entry { border-bottom-color: rgba(255,255,255,0.07); }
.critical-section .img-slot { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1); }
.critical-section .img-slot span { color: rgba(255,255,255,0.2); }
.critical-section .entry-label { color: var(–blue); }
.critical-section .entry-cost { color: rgba(255,255,255,0.3); }
.critical-section .entry-title { color: #fff; }
.critical-section .entry-meta { color: rgba(255,255,255,0.3); }
.critical-section .entry-tag { border-color: rgba(255,255,255,0.12); }
.critical-section .entry-blurb { color: rgba(255,255,255,0.5); }
.critical-section .map-link { color: var(–blue); border-color: rgba(168,196,216,0.35); }
.critical-section .map-link:hover { background: var(–blue); color: var(–ink); }

/* ── UPCOMING ── */
.upcoming-section { background: var(–bbg); }
.upcoming-section .section-label { color: var(–bd); }
.upcoming-section .entry { border-bottom-color: rgba(74,127,160,0.1); }
.upcoming-tag {
display: inline-block; font-family: var(–mono); font-size: 0.46rem;
letter-spacing: 0.14em; text-transform: uppercase; color: var(–bd);
border: 1px solid var(–blue); padding: 0.12rem 0.38rem; border-radius: 2px; margin-bottom: 0.6rem;
}

/* ── FOOTER ── */
footer { padding: 1.5rem 1.25rem; border-top: 1px solid var(–rule); background: var(–white); }
footer p {
font-family: var(–mono); font-size: 0.48rem;
letter-spacing: 0.13em; text-transform: uppercase; color: var(–low);
}

@media (min-width: 600px) {
.city-header, .entry, .section-label, .alpha-index, .filter-bar, .borough-header, footer,
.no-results { padding-left: 2rem; padding-right: 2rem; }
.top-bar, .section-bar { padding-left: 2rem; padding-right: 2rem; }
}
</style>

</head>
